#
# Khronos31 | .commonrc
#

[ -f ~/.common_aliases ] && . ~/.common_aliases

export LANG="ja_JP.UTF-8"

export THEOS="$HOME/theos"
export GOPATH="$HOME/go"
export NIMBLE_DIR="$HOME/.nimble"
export CARGO_HOME="$HOME/.cargo"
export PATH="$THEOS/bin:$GOPATH/bin:$NIMBLE_DIR/bin:$CARGO_HOME/bin:$PATH"

if [ -d "$HOME/bin" ]; then
  export PATH="$HOME/bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ]; then
  export PATH="$HOME/.local/bin:$PATH"
fi

if ! command -v which >/dev/null 2>&1; then
  # Termux/HAOS(Debian minimal)等、whichコマンド自体が入っていない環境向けのポータブル代替。
  # command -v だけで完結するのでPOSIX準拠。
  which() {
    local cmd found=1
    for cmd in "$@"; do
      if command -v "$cmd" >/dev/null 2>&1; then
        command -v "$cmd"
        found=0
      else
        printf '%s not found\n' "$cmd" >&2
      fi
    done
    return $found
  }
fi

if command -v luarocks >/dev/null; then
  eval "$(luarocks path)"
fi

if command -v opam >/dev/null; then
  eval "$(opam env)"
fi

[ -d "/Applications/Filza.app" ] &&
filza() {
  local suffix=""
  local filepath="."
  if [ $# -ge 1 ]; then
    filepath="$1"
  fi
  if ! [ -e "$filepath" ]; then
    printf 'filza: no such file or directory: %s\n' "$filepath" >&2
    return 1
  elif [ -d "$filepath" ]; then
    suffix="/."
  fi
  uiopen filza://view/"$(realpath -z "$filepath"|tr -d '\0'|od -tx1 -v -An|tr ' ' '%'|tr -d '\n')""$suffix"
}

_clip_osc52() {
  printf '\033]52;c;%s\a' "$(cat | base64 | tr -d '\n')"
}

if command -v pbcopy >/dev/null; then
  _clip_backend() { command pbcopy; }
elif command -v xclip >/dev/null; then
  _clip_backend() { xclip -selection c; }
  alias pbpaste='xclip -selection c -o'
elif command -v termux-clipboard-set >/dev/null; then
  _clip_backend() { termux-clipboard-set; }
  alias pbpaste='termux-clipboard-get'
elif [ -r /dev/clipboard ]; then
  _clip_backend() { cat >/dev/clipboard; }
  pbpaste() {
    cat /dev/clipboard
  }
fi

if command -v _clip_backend >/dev/null 2>&1; then
  # --osc52 を指定した時だけOSC52経由（SSH越しでも手元の端末に届く。書き込み専用）。
  # 指定が無ければ従来通りのローカルのバックエンドを使う。
  clip_command='pbcopy'
  pbcopy() {
    if [ "$1" = "--osc52" ]; then
      _clip_osc52
    else
      _clip_backend
    fi
  }
elif [ -t 1 ]; then
  # ローカルのクリップボード手段が何も見つからない場合の最終フォールバック。
  clip_command='pbcopy'
  pbcopy() {
    _clip_osc52
  }
fi

# aliases and environment variables for textimg
export RUNEWIDTH_EASTASIAN=1
export TEXTIMG_FONT_FILE="$HOME/Library/Fonts/PlemolJP-Text.ttf"
export TEXTIMG_EMOJI_DIR="$HOME/Library/Fonts/emoji/noto-emoji/png/128"
alias textimg='TEXTIMG_OUTPUT_DIR="$(pwd)" textimg'

if command -v ldid >/dev/null; then
  if [ -f /usr/share/entitlements/general.xml ]; then
    export ENTFILE="/usr/share/entitlements/general.xml"
  fi
  resign() {
    local file
    for file in "$@"; do
      ldid -S"$ENTFILE" -M "$file"
    done
  }
fi

hostname_color="$(
  [ -f /etc/os-release ] && . /etc/os-release
  echo "$((0x$(echo -n "$(uname -n)$NAME"|md5sum|head -c8) % 214 + 17))"
)"
